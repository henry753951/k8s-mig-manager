{
  "name": "k8s-mig-manager",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "k8s-mig-manager": "./src/index.tsx"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "build": "node scripts/build.mjs",
    "check": "bunx --bun @biomejs/biome@2.4.12 check .",
    "check:fix": "bunx --bun @biomejs/biome@2.4.12 check --write .",
    "format": "bunx --bun @biomejs/biome@2.4.12 format --write .",
    "lint": "bunx --bun @biomejs/biome@2.4.12 lint ./src",
    "lint:fix": "bunx --bun @biomejs/biome@2.4.12 lint --write ./src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "react": "^19.2.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "^1.3.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "esbuild": "^0.25.11",
    "typescript": "^5.9.3"
  }
}
